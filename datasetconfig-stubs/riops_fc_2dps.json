{
    "riops_fc_2dps": {
        "group": "RIOPS Forecast",
        "subgroup": "2D",                
        "climatology": "http://navigator.oceansdata.ca:8080/thredds/dodsC/climatology/Levitus98_PHC21/aggregated.ncml",
        "enabled": true,
        "help": "https://eccc-msc.github.io/open-data/msc-data/nwp_riops/readme_riops_en/",
        "name": "RIOPS Forecast Surface - Polar Stereographic",
        "quantum": "hour",
        "type": "forecast",
        "time_dim_units": "seconds since 1950-01-01 00:00:00",
        "model_class": "Nemo",
        "url": "icechunk",
        "grid_angle_file_url": "/data/grids/ecc/riops/grid_angle_riops_ps5km60n.nc",
        "attribution": "The Canadian Centre for Meteorological and Environmental Prediction",
        "lat_var_key": "latitude",
        "lon_var_key": "longitude",
        "vector_variables": ["magwatervel"],
        "variables": {
            "votemper": { "name": "Potential Temperature", "units": "Celsius", "scale": [-5, 30], "equation": "votemper - 273.15", "dims": ["time", "yc", "xc"], "valid_min": -100, "valid_max": 100 },
            "vosaline": { "name": "Salinity", "units": "PSU", "scale": [30, 40] },
            "vozocrtx": { "hide": "true", "name": "Water X Velocity", "units": "m/s", "scale": [-3, 3], "zero_centered": "true" },
            "vomecrty": { "hide": "true", "name": "Water Y Velocity", "units": "m/s", "scale": [-3, 3], "zero_centered": "true" },
            "vozocrte": { "name": "Water East Velocity", "units": "m/s", "scale": [-3, 3], "equation": "vozocrtx * cos_alpha - vomecrty * sin_alpha", "zero_centered": "true", "dims": ["time", "yc", "xc"] },
            "vomecrtn": { "name": "Water North Velocity", "units": "m/s", "scale": [-3, 3], "equation": "vozocrtx * sin_alpha + vomecrty * cos_alpha", "zero_centered": "true", "dims": ["time", "yc", "xc"] },
            "magwatervel": { "name": "Water Velocity", "units": "m/s", "scale": [0, 3], "equation": "magnitude(vozocrtx, vomecrty)",  "dims": ["time", "yc", "xc"], "east_vector_component": "vozocrte", "north_vector_component": "vomecrtn" },
            "sossheig": { "name": "Sea Surface Height", "units": "m", "scale": [-3, 3], "zero_centered": "true" },
            "somixhgt": { "name": "Turbocline Depth", "units": "m", "scale": [0, 4000] },
            "sokaraml": { "name": "Ocean Mixed Layer Depth", "units": "m", "scale": [0, 4000] },
            "iiceconc": { "name": "Ice Concentration", "units": "fraction", "scale": [0, 1] },
            "iicevol": { "name": "Ice Volume", "units": "m", "scale": [0, 10] },
            "iicesurftemp": { "name": "Surface Temp Over Sea Ice", "units": "Celsius", "scale": [-5, 30], "equation": "iicesurftemp - 273.15", "dims": ["time", "yc", "xc"] },
            "isnowvol": { "name": "Snow Volume", "units": "cm", "scale": [0, 2000] },
            "itmecrty": { "hide": "true", "name": "Sea Ice Y Velocity", "units": "m/s", "scale": [-1, 1], "zero_centered": "true" },
            "itzocrtx": { "hide": "true", "name": "Sea Ice X Velocity", "units": "m/s", "scale": [-1, 1], "zero_centered": "true" },
            "itzocrte": { "name": "Sea Ice East Velocity", "units": "m/s", "scale": [-1, 1], "equation": "itzocrtx * cos_alpha - itmecrty * sin_alpha", "zero_centered": "true", "dims": ["time", "yc", "xc"] },
            "itmecrtn": { "name": "Sea Ice North Velocity", "units": "m/s", "scale": [-1, 1], "equation": "itzocrtx * sin_alpha + itmecrty * cos_alpha", "zero_centered": "true", "dims": ["time", "yc", "xc"] },
            "icevelocity": { "name": "Sea Ice Velocity", "units": "m/s", "scale": [0, 1], "equation": "magnitude(itzocrtx, itmecrty)", "dims": ["time", "yc", "xc"], "east_vector_component": "itzocrte", "north_vector_component": "itmecrtn" },
            "iicestrength": { "name": "Compressive Ice Strength", "units": "Nm-1", "scale": [-1, 1] },
            "iicepressure": { "name": "Internal Ice Pressure", "units": "Nm-1", "scale": [-1, 1] }
        }
    }
}