{
    "gdwps_2dll": {
        "group": "GDWPS Forecast",
        "subgroup": "2D",
        "url": "http://192.168.10.3:8090/thredds/dodsC/ECCC/model_gdwps",
        "name": "GDWPS 5 day Forecast 2D - LatLon",
        "quantum": "hour",
        "type": "forecast",
        "model_class": "Mercator",
        "enabled": false,
        "attribution": "The Canadian Centre for Meteorological and Environmental Prediction",
        "lat_var_key": "lat",
        "lon_var_key": "lon",
        "help": "https://eccc-msc.github.io/open-data/msc-data/nwp_gdwps/readme_gdwps_en",
        "vector_variables": ["Direction_of_wind_waves_surface", "Peak_wave_direction_surface", "magwindvel"],
        "variables": {
            "Direction_of_wind_waves_surface": { "name": "Wind wave direction", "units": "degrees", "scale": [0, 360] },
            "Mean_wave_direction_of_first_swell_partition_surface": { "name": "Mean wave direction of first swell partition", "units": "degrees", "scale": [0, 360] },
            "Mean_wave_direction_of_second_swell_partition_surface": { "name": "Mean wave direction of second swell partition", "units": "degrees", "scale": [0, 360] },
            "Mean_zero-crossing_wave_period_surface": { "name": "Mean zero-crossing wave period", "units": "s", "scale": [1, 24] },
            "Peak_period_of_wind_waves_surface": { "name": "Peak wave period of wind waves", "units": "s", "scale": [1, 24] },
            "Peak_wave_direction_surface": { "name": "Peak wave direction", "units": "degrees", "scale": [0, 360] },
            "Peak_wave_period_surface": { "name": "Peak wave period", "units": "s", "scale": [1, 24] },
            "Significant_height_of_combined_wind_waves_and_swell_surface": { "name": "Significant wave height of combined wind waves and swell", "units": "m", "scale": [0, 10] },
            "Significant_height_of_wind_waves_surface": { "name": "Significant wave height of wind waves", "units": "m", "scale": [0, 10] },
            "Significant_wave_height_of_first_swell_partition_surface": { "name": "Significant wave height of first swell partition", "units": "m", "scale": [0, 10] },
            "Significant_wave_height_of_second_swell_partition_surface": { "name": "Significant wave height of second swell partition", "units": "m", "scale": [0, 10] },
            "u-component_of_wind_height_above_ground": { "name": "u component of wind", "units": "m", "scale": [-25, 25], "zero_centered": "true" },
            "v-component_of_wind_height_above_ground": { "name": "v component of wind", "units": "m", "scale": [-25, 25], "zero_centered": "true" },
            "VAR10-0-65_FROM_54-0--1_surface": { "name": "Peak wave period of first swell partition", "units": "s", "scale": [1, 24] },
            "VAR10-0-66_FROM_54-0--1_surface": { "name": "Peak wave period of second swell partition", "units": "s", "scale": [1, 24] },
            "magwindvel": { "name": "Wind Velocity", "units": "m/s", "scale": [0, 25], "equation": "magnitude(u-component_of_wind_height_above_ground, v-component_of_wind_height_above_ground)",  "dims": ["time", "height_above_ground", "lat", "lon"], "east_vector_component": "u-component_of_wind_height_above_ground", "north_vector_component": "v-component_of_wind_height_above_ground", "bearing_component":"wind_bearing" },
            "wind_bearing": { "hide": "true", "name": "Wind Velocity Bearing (deg clockwise +tive from N)", "units": "degrees", "scale": [0, 360], "equation": "bearing(u-component_of_wind_height_above_ground, v-component_of_wind_height_above_ground)", "dims": ["time", "height_above_ground", "lat", "lon"] }
        }
    }
}