{
    "stle200-hindcast": {
        "group": "POPS Hindcast",
        "subgroup": "St. Lawrence River",           
        "enabled": true,
        "help": "https://dfo-ocean-navigator.github.io/Dataset-Descriptions/#port-ocean-prediction-systems-pops",
        "name": "St. Lawrence River Hindcast - 200m",
        "quantum": "hour",
        "type": "forecast",
        "time_dim_units": "seconds since 1950-01-01 00:00:00",
        "model_class": "Nemo",
        "url": "/data/db/stle200_hindcast.sqlite3",
        "attribution": "The Canadian Centre for Meteorological and Environmental Prediction",
        "lat_var_key": "lat",
        "lon_var_key": "lon",
        "default_location": [-69.9, 47.7, 8],
        "vector_variables": ["magwatervel"],
        "variables": {
            "so": { "name": "Salinity", "units": "PSU", "scale": [30, 40] },
            "to": { "name": "Potential Temperature", "units": "Celsius", "scale": [-5, 30], "equation": "to - 273.15", "dims": ["time", "depth", "y", "x"], "valid_min": -100, "valid_max": 100 },
            "uo": { "name": "Water X Velocity", "units": "m/s", "scale": [-3, 3], "zero_centered": "true" },
            "vo": { "name": "Water Y Velocity", "units": "m/s", "scale": [-3, 3], "zero_centered": "true" },
            "zos": { "name": "Sea Surface Height", "units": "m", "scale": [-3, 3] },
            "magwatervel": { "name": "Water Velocity", "units": "m/s", "scale": [0, 3], "equation": "magnitude(uo, vo)",  "dims": ["time", "depth", "y", "x"], "east_vector_component": "uo", "north_vector_component": "vo", "bearing_component": "bearing" },
            "bearing": { "hide": "true", "name": "Water Velocity Bearing (deg clockwise +tive from N)", "units": "degrees", "scale": [0, 360], "equation": "bearing(vos, uos)" ,"dims": ["time", "y", "x"] }
        }
    }
}