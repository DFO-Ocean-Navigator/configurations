{
    "caps_fc_2drp": {
        "group": "CAPS Forecast",
        "subgroup": "2D",          
        "enabled": true,
        "help": "https://eccc-msc.github.io/open-data/msc-data/nwp_caps/readme_caps_en/",
        "name": "CAPS Forecast 2D - Rotated Pole",
        "quantum": "hour",
        "type": "forecast",
        "time_dim_units": "seconds since 1950-01-01 00:00:00",
        "model_class": "Nemo",
        "url": "icechunk",
        "grid_angle_file_url": "/data/grids/ecc/caps/grid_angle_caps_rp.nc",
        "attribution": "The Canadian Centre for Meteorological and Environmental Prediction",
        "lat_var_key": "latitude",
        "lon_var_key": "longitude",
        "variables": {
            "votemper": { "name": "Potential Temperature", "units": "Celsius", "scale": [-5, 30], "equation": "votemper - 273.15", "dims": ["time", "rlat", "rlon"], "valid_min": -100, "valid_max": 100 },
            "vosaline": { "name": "Salinity", "units": "PSU", "scale": [30, 40] },
            "vozocrtx": { "hide": "true", "name": "Water X Velocity", "units": "m/s", "scale": [-3, 3], "zero_centered": "true" },
            "vomecrty": { "hide": "true", "name": "Water Y Velocity", "units": "m/s", "scale": [-3, 3], "zero_centered": "true" },
            "vozocrte": { "name": "Water East Velocity", "units": "m/s", "scale": [-3, 3], "equation": "vozocrtx * cos_alpha - vomecrty * sin_alpha", "zero_centered": "true", "dims": ["time", "rlat", "rlon"] },
            "vomecrtn": { "name": "Water North Velocity", "units": "m/s", "scale": [-3, 3], "equation": "vozocrtx * sin_alpha + vomecrty * cos_alpha", "zero_centered": "true", "dims": ["time", "rlat", "rlon"] },
            "sossheig": { "name": "Sea Surface Height", "units": "m", "scale": [-3, 3], "zero_centered": "true" },
            "somixhgt": { "name": "Turbocline Depth", "units": "m", "scale": [0, 4000] },
            "sokaraml": { "name": "Ocean Mixed Layer Depth", "units": "m", "scale": [0, 4000] },
            "iiceconc": { "name": "Ice Concentration", "units": "fraction", "scale": [0, 1] },
            "iicevol": { "name": "Ice Volume", "units": "m", "scale": [0, 10] },
            "iicesurftemp": { "name": "Surface Temp Over Sea Ice", "units": "Celsius", "scale": [-5, 30], "equation": "iicesurftemp - 273.15", "dims": ["time", "rlat", "rlon"] },
            "isnowvol": { "name": "Snow Volume", "units": "cm", "scale": [0, 2000] },
            "itmecrty": { "name": "Sea Ice Y Velocity", "units": "m/s", "scale": [-1, 1], "zero_centered": "true" },
            "itzocrtx": { "name": "Sea Ice X Velocity", "units": "m/s", "scale": [-1, 1], "zero_centered": "true" },
            "iicestrength": { "name": "Compressive Ice Strength", "units": "Nm-1", "scale": [-1, 1] },
            "iicepressure": { "name": "Internal Ice Pressure", "units": "Nm-1", "scale": [-1, 1] },
            "iicedivergence": { "name": "Sea Ice Divergence", "units": "%/day", "scale": [-2, 2] }, 
            "iiceshear": { "name": "Sea Ice Shear", "units": "%/day", "scale": [-2, 2] }
        }
    }
}