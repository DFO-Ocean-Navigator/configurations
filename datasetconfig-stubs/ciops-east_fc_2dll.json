{
    "ciops-east_fc_2dll": {
        "group": "CIOPS Forecast",
        "subgroup": "East",        
        "url": "icechunk",
        "name": "CIOPS Forecast East Surface - LatLon",
        "quantum": "hour",
        "type": "forecast",
        "time_dim_units": "seconds since 1950-01-01 00:00:00",
        "model_class": "Mercator",
        "enabled": true,
        "climatology": "http://navigator.oceansdata.ca:8880/thredds/dodsC/climatology/Levitus98_PHC21/aggregated.ncml",
        "attribution": "The Canadian Centre for Meteorological and Environmental Prediction",
        "lat_var_key": "latitude",
        "lon_var_key": "longitude",
        "help": "https://eccc-msc.github.io/open-data/msc-data/nwp_ciops/readme_ciops_en/",
        "vector_variables": ["magwatervel"],
	    "default_location": [-57, 44.5, 4],
        "variables": {
            "vozocrtx": { "name": "Water East Velocity", "units": "m/s", "scale": [-3, 3], "zero_centered": "true" },
            "vomecrty": { "name": "Water North Velocity", "units": "m/s", "scale": [-3, 3], "zero_centered": "true" },
            "magwatervel": { "name": "Water Velocity", "units": "m/s", "scale": [0, 3], "equation": "magnitude(vozocrtx, vomecrty)",  "dims": ["time", "latitude", "longitude"], "east_vector_component": "vozocrtx", "north_vector_component": "vomecrty", "bearing_component": "bearing" },
            "bearing": { "hide": "true", "name": "Water Velocity Bearing (deg clockwise +tive from N)", "units": "degrees", "scale": [0, 360], "equation": "bearing(vomecrty, vozocrtx)" ,"dims": ["time", "latitude", "longitude"] },
            "votemper": { "name": "Potential Temperature", "units": "Celsius", "scale": [-5,30], "equation": "votemper - 273.15", "dims": ["time", "latitude", "longitude"] },
            "vosaline": { "name": "Salinity", "units": "PSU", "scale": [30, 40] },
            "sossheig": { "name": "Sea Surface Height", "units": "m", "scale": [-3, 3], "zero_centered": "true" },
            "iiceconc": { "name": "Ice Concentration", "units": "fraction", "scale": [0, 1] },
            "iicevol": { "name": "Ice Volume", "units": "m", "scale": [0, 10] },
            "somixhgt": { "name": "Turbocline Depth", "units": "m", "scale": [0, 4000] },
            "sokaraml": { "name": "Ocean Mixed Layer Depth", "units": "m", "scale": [0, 4000] },
            "iicesurftemp": { "name": "Surface Temp Over Sea Ice", "units": "Celsius", "scale": [-5, 30], "equation": "iicesurftemp - 273.15", "dims": ["time", "latitude", "longitude"] },
            "isnowvol": { "name": "Snow Volume", "units": "cm", "scale": [0, 2000] },
            "itmecrty": { "name": "Sea Ice North Velocity", "units": "m/s", "scale": [-1, 1], "zero_centered": "true" },
            "itzocrtx": { "name": "Sea Ice East Velocity", "units": "m/s", "scale": [-1, 1], "zero_centered": "true" },
            "icevelocity": { "name": "Sea Ice Velocity", "units": "m/s", "scale": [0, 1], "equation": "magnitude(itmecrty, itzocrtx)", "dims": ["time", "latitude", "longitude"], "east_vector_component": "itzocrtx", "north_vector_component": "itmecrty", "bearing_component": "bearing_seaice" },
            "bearing_seaice": { "hide": "true", "name": "Sea Ice Velocity Bearing (deg clockwise +tive from N)", "units": "degrees", "scale": [0, 360], "equation": "bearing(itzocrtx, itmecrty)" ,"dims": ["time", "latitude", "longitude"] },
            "iicestrength": { "name": "Compressive Ice Strength", "units": "Nm-1", "scale": [-1, 1] },
            "iicepressure": { "name": "Internal Ice Pressure", "units": "Nm-1", "scale": [-1, 1] }
         }
    }
}