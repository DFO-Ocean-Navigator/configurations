{
    "fundy500": {
        "group": "POPS Forecast",
        "subgroup": "Bay of Fundy",         
        "enabled": true,
        "help": "https://dfo-ocean-navigator.github.io/Dataset-Descriptions/#port-ocean-prediction-systems-pops",
        "name": "Bay of Fundy - 500m",
        "quantum": "hour",
        "type": "forecast",
        "time_dim_units": "seconds since 1950-01-01 00:00:00",
        "model_class": "Nemo",
        "url": "icechunk",
        "attribution": "The Canadian Centre for Meteorological and Environmental Prediction",
        "lat_var_key": "lat",
        "lon_var_key": "lon",
        "default_location": [-65.8, 45, 8],
        "vector_variables": ["magwatervel"],
        "variables": {
            "sos": { "name": "Salinity", "units": "PSU", "scale": [30, 40] },
            "tos": { "name": "Potential Temperature", "units": "Celsius", "scale": [-5, 30], "equation": "tos - 273.15", "dims": ["time", "y", "x"], "valid_min": -100, "valid_max": 100 },
            "uos": { "name": "Water X Velocity", "units": "m/s", "scale": [-3, 3], "zero_centered": "true" },
            "vos": { "name": "Water Y Velocity", "units": "m/s", "scale": [-3, 3], "zero_centered": "true" },
            "magwatervel": { "name": "Water Velocity", "units": "m/s", "scale": [0, 3], "equation": "magnitude(uos, vos)",  "dims": ["time", "y", "x"], "east_vector_component": "uos", "north_vector_component": "vos", "bearing_component": "bearing" },
            "bearing": { "hide": "true", "name": "Water Velocity Bearing (deg clockwise +tive from N)", "units": "degrees", "scale": [0, 360], "equation": "bearing(vos, uos)" ,"dims": ["time", "y", "x"] }
        }
    }
}